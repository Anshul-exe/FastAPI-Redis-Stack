# PostgreSQL
POSTGRES_USER=          # e.g. taskuser
POSTGRES_PASSWORD=      # strong password, never commit real value
POSTGRES_DB=            # e.g. taskdb

# Redis
# no extra vars needed, URL is constructed in compose

# App
RATE_LIMIT_PER_MINUTE=100   # requests per minute per IP
LOG_LEVEL=INFO              # logging level for the app (DEBUG, INFO, WARNING, ERROR)

# Constructed at runtime by compose (do not set manually)
# DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB
# REDIS_URL=redis://redis:6379/0
