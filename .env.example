LOG_LEVEL=INFO              # logging level for the app (DEBUG, INFO, WARNING, ERROR)

# Constructed at runtime by compose
# DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB
# REDIS_URL=redis://redis:6379/0

# Monitoring
GRAFANA_PASSWORD=
