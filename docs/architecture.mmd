    FastAPI -- "Cache read/write (port 6379)" --> Redis
    
    Prometheus -- "Scrapes metrics" --> FastAPI
    Grafana -- "Queries metrics" --> Prometheus
    Fail2Ban -. "Monitors logs & Bans IPs" .-> NGINX
    
    GHA -- "Build/push image" --> GHCR
    GHA -- "Deploy via SSH" --> NGINX
    
